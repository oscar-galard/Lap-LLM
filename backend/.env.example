# Database configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_123
POSTGRES_DB=lap_llm
DATABASE_URL=postgresql://admin:change_me_123@db:5432/lap_llm

# LLM Configuration
# Choose between: "deepseek" or "openrouter"
LLM_PROVIDER=deepseek

# DeepSeek Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter Configuration (for free models or backup)
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Examples: google/gemma-2-9b-it:free, meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# PDF settings & App
OPENAI_API_KEY=your_openai_api_key_here
PORT=8080
DEBUG=False

# CORS Origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://vestaagentic.com

# PDF path (inside docker container or your local path)
PDF_PATH=/app/data/Inferencia-LLM-en-dispositivos.pdf
